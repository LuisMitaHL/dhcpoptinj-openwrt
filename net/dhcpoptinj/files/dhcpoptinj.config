# dhcpoptinj UCI configuration
#
# Option hex format: first byte is the DHCP option code, followed by its payload.
# The length byte is automatically inserted. Any non-hex delimiter is ignored.
#
# Examples:
#   list option '0C:66:6A:61:73:65:68:6F:73:74'   # hostname "fjasehost" (opt 12)
#   list option '52:01:04:46:6A:61:73'             # relay agent "Fjas" (opt 82)
#   list option '32:0A:14:1E:28'                   # request IP 10.20.30.40 (opt 50)
#   list option '06080808080404'                   # DNS servers 8.8.8.8, 8.8.4.4 (opt 6)

config dhcpoptinj 'main'
	option enabled '0'
	option queue '0'
	# DHCP port to intercept:
	#   'none'    — no nftables rules (manage manually)
	#   'request' — client requests only (port 67)
	#   'reply'   — server replies only (port 68)
	#   'both'    — both directions (default)
	option snoop 'both'
	# Bridge interface to match (e.g. 'br-lan'). Empty = all.
	option interface ''
	# Bridge interfaces to exclude (e.g. 'eth0'). Packets from these interfaces
	# will NOT be queued. Useful to avoid injecting into LAN-originated traffic.
	# Multiple exclusions are supported:
#	list exclude_interface 'eth0'
#	list exclude_interface 'eth1'
	option debug '0'
	option forward_on_fail '0'
	option conflict ''
	option pid_file ''
#	list option '0C:66:6A:61:73:65:68:6F:73:74'
